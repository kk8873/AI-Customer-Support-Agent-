# Copy to .env and fill in. .env is gitignored — never commit real keys.

# ── LLM provider (provider-agnostic — pick one) ───────────────────────
LLM_PROVIDER=openai                  # openai | gemini
LLM_MODEL=gpt-4.1-mini               # provider-appropriate model id (e.g. gemini-1.5-flash)
OPENAI_API_KEY=                      # required when LLM_PROVIDER=openai
GEMINI_API_KEY=                      # required when LLM_PROVIDER=gemini

# ── Database (local PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/refund_agent

# ── Agent loop ────────────────────────────────────────────────────────
MAX_STEPS=6                          # hard cap on agent loop iterations

# ── Voice (Phase 10+, optional — leave blank until then) ──────────────
# DEEPGRAM_API_KEY=                  # STT, if using Deepgram
# ELEVENLABS_API_KEY=                # TTS, if using ElevenLabs
# (or use OpenAI Whisper for STT + OpenAI TTS — then no extra key needed)
